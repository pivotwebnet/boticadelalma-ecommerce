generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Orden creada por el webhook de MercadoPago al confirmar el pago
model Order {
  id          String      @id @default(uuid())
  status      String      @default("pending") // pending, paid, shipped, cancelled
  total       Int
  customerName  String
  customerEmail String
  customerPhone String?
  address     String?
  city        String?
  notes       String?
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt // <-- NUEVA LÍNEA: Auditoría de cambios de estado
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String  // <-- NUEVA LÍNEA: Guarda el nombre del producto al momento de compra
  pricePaid   Int     // <-- NUEVA LÍNEA: Guarda el precio histórico cobrado
  quantity    Int
}

model Comment {
  id        String   @id @default(uuid())
  productId String
  orderId   String   // <-- Volvemos a vincularlo a la orden para validar la compra
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author    String
  text      String   @db.VarChar(300) // Limita los caracteres en Postgres para evitar textos gigantes
  rating    Int      
  createdAt DateTime @default(now())

  @@unique([orderId, productId]) // <-- Evita que la misma persona comente dos veces el mismo producto por la misma compra
  @@index([productId])
}